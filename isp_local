# Clash Meta for Android / Mihomo profile rebuilt from local_group.conf.
# 设计目标：
# - 国内、局域网、银行和用户自维护域名尽量直连。
# - AI、Google、GitHub 等账号或风控敏感服务走“静态住宅”。
# - YouTube、Google Photos、流媒体、社交、游戏平台等高流量国外服务走“赠送美国”。
# - 默认 DNS 通过代理侧 DoH 解析，只有 RaymondDirect 这类明确直连域名使用系统 DNS。
# Android 端建议关闭系统“私人 DNS”，否则系统可能绕过 TUN DNS hijack。

mixed-port: 7890
allow-lan: false
mode: rule
log-level: info
ipv6: false
unified-delay: true
tcp-concurrent: true
find-process-mode: strict

sniffer:
  # 纯 IP 或被 App 隐藏域名的连接，尽量通过 TLS/HTTP/QUIC 嗅探还原目标域名。
  # 这样规则可以按域名命中；override-destination 保持 false，避免全局改写目标地址。
  enable: true
  force-dns-mapping: true
  parse-pure-ip: true
  override-destination: false
  sniff:
    TLS:
      ports: [443, 8443]
    HTTP:
      ports: [80, 8080-8880]
      override-destination: true
    QUIC:
      ports: [443, 8443]

profile:
  store-selected: true
  store-fake-ip: true

tun:
  # TUN 接管 Android 系统流量，并劫持 53 端口 DNS 到 Mihomo。
  # route-exclude-address 保留局域网、回环、保留网段和组播直连，避免破坏本地网络发现。
  enable: true
  stack: system
  auto-route: true
  auto-detect-interface: true
  strict-route: true
  dns-hijack:
    - any:53
    - tcp://any:53
  route-exclude-address:
    - 10.0.0.0/8
    - 100.64.0.0/10
    - 127.0.0.0/8
    - 169.254.0.0/16
    - 172.16.0.0/12
    - 192.0.0.0/24
    - 192.0.2.0/24
    - 192.88.99.0/24
    - 192.168.0.0/16
    - 198.51.100.0/24
    - 203.0.113.0/24
    - 224.0.0.0/4
    - 239.255.255.250/32
    - 255.255.255.255/32

dns:
  # DNS 总策略：
  # - fake-ip 用于让 Mihomo 接管域名解析和后续规则匹配。
  # - nameserver 和 fallback 都通过 #PROXY 走代理侧 DoH，减少本地 DNS 泄露。
  # - respect-rules=false 表示 DNS 查询不按最终分流规则自动选择出口。
  # - 只有 nameserver-policy 明确写出的 RaymondDirect 使用 Android 当前网络的系统 DNS。
  enable: true
  listen: 0.0.0.0:1053
  ipv6: false
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16
  fake-ip-filter-mode: blacklist
  use-hosts: true
  use-system-hosts: false
  respect-rules: false
  fake-ip-filter:
    # 下列域名不分配 fake-ip，保持真实解析或本地语义，避免局域网、NTP、银行和 captive portal 异常。
    - "*.lan"
    - "*.local"
    - "localhost"
    - "localhost.*"
    - "captive.apple.com"
    - "*.ccb.com"
    - "*.abchina.com.cn"
    - "*.psbc.com"
    - "time.*.com"
    - "time.*.gov"
    - "ntp.*.com"
    - "ntp.*.org"
  default-nameserver:
    # 用于解析 DoH 服务器本身等 bootstrap 场景；这里是 IP，避免 bootstrap 再依赖域名。
    - 1.1.1.1
    - 8.8.8.8
  proxy-server-nameserver:
    # 代理节点、远程规则和 provider 相关域名优先用可信 DoH 解析。
    - https://cloudflare-dns.com/dns-query
    - https://dns.google/dns-query
  nameserver-policy:
    # RaymondDirect 是用户自维护直连域名集合。
    # 这些域名通常需要国内 CDN、企业服务或系统服务的本地化解析，所以使用当前网络的系统 DNS。
    # 新增 RaymondDirect 域名时，需要同时判断它是否适合暴露给系统 DNS。
    "rule-set:RaymondDirect":
      - "dhcp://system"
  nameserver:
    # 默认 DNS 出口：经 PROXY 访问 Cloudflare / Google DoH，避免普通域名解析落到本地运营商。
    - "https://cloudflare-dns.com/dns-query#PROXY"
    - "https://dns.google/dns-query#PROXY"
  fallback:
    # 备用 DoH，同样强制经 PROXY；fallback-filter 用于处理可能污染或异常的返回。
    - "https://dns.quad9.net/dns-query#PROXY"
    - "https://cloudflare-dns.com/dns-query#PROXY"
  fallback-filter:
    geoip: true
    geoip-code: CN
    ipcidr:
      - 240.0.0.0/4

hosts:
  localhost: 127.0.0.1

proxies: []

proxy-providers:
  # 机场 provider 是订阅节点来源，真实订阅 URL 属于敏感信息，不能写入聊天、文档或提交说明。
  # health-check 只用于确认节点连通性，不改变分流规则本身。
  机场equaldcdn:
    type: http
    url: "https://equaldcdn.com/use/unsafe/sub.php?&s=69bfa134618ebc9a5f880cc055d1cecd1fcafd77de295e446d6bb86234eb07e4"
    path: ./providers/airport.yaml
    interval: 86400
    proxy: DIRECT
    header:
      User-Agent:
        - clash.meta
    health-check:
      enable: true
      url: http://www.gstatic.com/generate_204
      interval: 600
      timeout: 5000
      lazy: true
      expected-status: 204
    override:
      udp: true
  机场悠兔:
    type: http
    url: "https://b.youtulink3.top/dy/2a30b4b12692f127cf87f39da8378269"
    path: ./providers/airport_youtu.yaml
    interval: 86400
    proxy: DIRECT
    header:
      User-Agent:
        - clash.meta
    health-check:
      enable: true
      url: http://www.gstatic.com/generate_204
      interval: 600
      timeout: 5000
      lazy: true
      expected-status: 204
    override:
      udp: true

proxy-groups:
  # PROXY 是未命中特定服务规则后的手工兜底入口。
  # 下面两个自动测速组按节点名称过滤：账号敏感服务优先静态住宅，高流量服务优先赠送美国。
  - name: PROXY
    type: select
    proxies:
      - 静态住宅
      - 赠送美国
    use:
      - 机场equaldcdn

  - name: 静态住宅
    # 静态住宅 IP 更像稳定家庭宽带出口，适合 AI、Google、GitHub 等更看重账号信誉和风控一致性的服务。
    # 不把大流量媒体默认放这里，是为了避免消耗高价值住宅流量。
    type: url-test
    use:
      - 机场equaldcdn
    filter: "静态.*住宅|住宅.*静态"
    url: http://www.gstatic.com/generate_204
    interval: 600
    tolerance: 0
    timeout: 5000
    lazy: false
    expected-status: 204

  - name: 赠送美国主选
    # 主选：两个机场里所有名字包含“美国”且不包含“静态”的节点，按测速结果自动选择最快节点。
    type: url-test
    use:
      - 机场equaldcdn
      - 机场悠兔
    filter: "美国"
    exclude-filter: "静态"
    url: http://www.gstatic.com/generate_204
    interval: 600
    tolerance: 0
    timeout: 5000
    lazy: false
    expected-status: 204

  - name: 赠送非美兜底
    # 兜底：美国非静态节点都不可用时，再从日本、台湾或新加坡的非静态节点中选最快节点。
    type: url-test
    use:
      - 机场equaldcdn
      - 机场悠兔
    filter: "日本|台湾|台灣|新加坡"
    exclude-filter: "静态"
    url: http://www.gstatic.com/generate_204
    interval: 600
    tolerance: 0
    timeout: 5000
    lazy: false
    expected-status: 204

  - name: 赠送美国
    # 赠送美国用于成本更低、流量更大的节点池；优先美国非静态节点，全不可用时再使用非美兜底。
    # YouTube、Google Photos、流媒体、社交、游戏平台等优先走这里，降低静态住宅节点消耗。
    type: fallback
    proxies:
      - 赠送美国主选
      - 赠送非美兜底
    url: http://www.gstatic.com/generate_204
    interval: 600
    timeout: 5000
    lazy: false
    expected-status: 204

rule-providers:
  # rule-providers 是远程规则集缓存：
  # - RaymondDirect 来自本仓库文本规则，既用于 DIRECT 路由，也用于 DNS nameserver-policy。
